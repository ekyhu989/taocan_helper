{
  "version": 2,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ],
  "regions": ["hkg1"],
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/scheme", "destination": "/", "statusCode": 308 },
    { "source": "/product", "destination": "/", "statusCode": 308 },
    { "source": "/export", "destination": "/", "statusCode": 308 }
  ],
  "git": {
    "deploymentEnabled": { "main": true, "develop": true },
    "autoAlias": true
  },
  "alias": ["taocang-helper-v2.vercel.app", "staging.taocang.com", "dev.taocang.com", "prod.taocang.com"]
}
