{
  "version": 2,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "X-Frame-Options": "SAMEORIGIN",
        "X-Content-Type-Options": "nosniff",
        "X-XSS-Protection": "1; mode=block",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://*.cloudbase.tencent.com https://*.tencentcs.com; frame-src 'self'; object-src 'none'",
        "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
      }
    }
  ],
  "redirects": [
    { "source": "/scheme", "destination": "/", "statusCode": 308 },
    { "source": "/product", "destination": "/", "statusCode": 308 },
    { "source": "/export", "destination": "/", "statusCode": 308 }
  ],
  "regions": ["hkg1", "sfo1"],
  "public": true,
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    },
    "autoAlias": true
  }
}
